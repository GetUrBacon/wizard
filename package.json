{
  "name": "@geturbacon/wizard",
  "version": "0.3.3",
  "description": "One-command setup wizard for the Bacon ad network",
  "type": "module",
  "bin": {
    "bacon-wizard": "bin/wizard.cjs"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "scripts": {
    "start": "node bin/wizard.cjs",
    "prestart": "npm run build",
    "build": "esbuild 'src/ui/*.js' 'src/ui/*.jsx' --outdir=dist/ui --bundle=false --format=esm --platform=node --target=node18 --jsx=transform --jsx-factory=React.createElement --jsx-fragment=React.Fragment",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test 'tests/*.test.js'"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^4.1.2",
    "figures": "^6.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "ink-testing-library": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GetUrBacon/wizard.git"
  },
  "keywords": [
    "bacon",
    "claude",
    "ads",
    "developer-monetization"
  ],
  "license": "MIT"
}
